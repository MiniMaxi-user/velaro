// Velaro MVP — datamodel (stap 1)
// Scope: pensionstal-beachhead, rond het centrale paardenprofiel.
// Alleen de kern-entiteiten. Gezondheid/planning/facturatie volgen in latere stappen
// en haken aan op Horse — nu nog NIET modelleren (premature complexiteit).
//
// Auth: Supabase Auth doet authenticatie. Elke User-rij spiegelt een auth-user:
//   User.id == auth.users.id (uuid). Autorisatie regelen wij in de app-laag op basis
//   van StableMember (stalrol) en HorseOwner (eigendom).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Gebruikers ──────────────────────────────────────────────────────────────

model User {
  id              String   @id @db.Uuid // == Supabase auth user id
  email           String   @unique
  name            String?
  isPlatformAdmin Boolean  @default(false)
  maxStables      Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Een gebruiker kan staf/eigenaar van stallen zijn én eigenaar/bereider van paarden.
  stableMemberships StableMember[]
  horsePeople       HorsePerson[]
  messages          Message[]
  messageReads      MessageRead[]
  // Contracten waarin deze gebruiker de wederpartij (paardeigenaar) is.
  counterpartyContracts Contract[] @relation("ContractCounterparty")

  // Lease-overeenkomsten waarin deze gebruiker de leaser is (#59).
  leases                Lease[]

  // Lease-marktplaats (Lease 05, #64): interesse-gesprekken die deze gebruiker is
  // gestart, en de losse berichten die deze gebruiker schreef.
  leaseInquiries        LeaseInquiry[]        @relation("LeaseInquirer")
  leaseInquiryMessages  LeaseInquiryMessage[]

  // Geclaimde dagdelen in de beschikbaarheidskalender (Lease 09, #68).
  dagdeelClaims         LeaseDagdeelClaim[]

  // Zakelijke / facturatiegegevens staan in een apart, 1-1 gekoppeld profiel
  // (alleen relevant voor staleigenaar-accounts). Optioneel: niet elk account
  // heeft een profielrij.
  businessProfile OwnerBusinessProfile?

  // Facturen waarvan deze gebruiker de ontvanger is (paardeigenaar/leaser), Fact 01.
  // onDelete: SetNull op Invoice — facturen overleven het verwijderen van het account.
  invoices Invoice[]
}

// ── Zakelijke / facturatiegegevens (fundament voor facturatie) ────────────────
// 1-1 gekoppeld aan User via de unieke FK userId. Bewust afgesplitst van het
// account-model zodat accounts zonder zakelijke gegevens (admin, stalmedewerker,
// bereider, paardeneigenaar) geen ongebruikte kolommen meedragen. Alle velden
// optioneel/plat gehouden, conform de adresconventie op Stable. Primair bedoeld
// voor staleigenaar-accounts (de te factureren klant).
model OwnerBusinessProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String? // bedrijfs-/factuurnaam
  address     String?
  postalCode  String?
  city        String?
  country     String?
  kvkNumber   String? // KvK-nummer
  vatNumber   String? // btw-nummer

  // Afwijkend factuuradres: pas relevant wanneer aangevinkt. Staat dit uit, dan
  // geldt het hoofdadres hierboven als factuuradres.
  separateInvoiceAddress Boolean @default(false)
  invoiceAddress         String?
  invoicePostalCode      String?
  invoiceCity            String?
  invoiceCountry         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Stal (pensionbedrijf) ────────────────────────────────────────────────────

model Stable {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  // Adres bewust plat gehouden voor de MVP.
  address    String?
  postalCode String?
  city       String?

  // Contactgegevens
  phone   String?
  email   String?
  website String?

  // Omschrijving / over de stal
  description String?

  // Eigen stallogo (huisstijl) voor o.a. de contract-PDF. Verwijst naar het pad/key
  // binnen de privé Supabase Storage-bucket voor stallogo's; null = standaard
  // Velaro-logo. Per stal instelbaar (een OWNER met meerdere stallen kan per stal
  // een ander logo hebben).
  logoPath String?

  // Algemene voorwaarden (juridische voorwaarden) als geüploade PDF op stalniveau
  // (#143). Verwijst naar het pad/key binnen de privé Supabase Storage-bucket voor
  // algemene voorwaarden; null = geen AV ingesteld. Per contract aan/uit te zetten
  // en — wanneer aan — als pagina's meegevoegd in het samengevoegde contractdocument.
  // Spiegelt het stallogo-patroon (logoPath, logoStorage.ts).
  algemeneVoorwaardenPath String?

  // Openingstijden (vrij tekstveld, bv. "Ma-vr 07:00-21:00")
  openingHours String?

  // Factuuradres (indien afwijkend)
  invoiceAddress    String?
  invoicePostalCode String?
  invoiceCity       String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members        StableMember[]
  horses         Horse[]
  tasks          Task[]
  recurringTasks RecurringTask[]
  messages       Message[]
  contracts      Contract[]
  // Facturen die deze stal uitgeeft (Fact 01).
  invoices       Invoice[]
}

// Koppelt een gebruiker aan een stal met een rol (staf/eigenaar van de stal).
// Dit bepaalt of iemand alle paarden ván die stal mag zien/beheren.
model StableMember {
  id        String     @id @default(uuid()) @db.Uuid
  stableId  String     @db.Uuid
  userId    String     @db.Uuid
  role      StableRole
  createdAt DateTime   @default(now())

  stable Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stableId, userId])
  @@index([userId])
}

enum StableRole {
  OWNER // staleigenaar — volledige rechten binnen de stal
  STAFF // stalmedewerker — beperktere rechten
}

// ── Paard (centraal profiel) ─────────────────────────────────────────────────

model Horse {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  // Basisgegevens — uit te breiden, maar dit is de kern.
  breed       String? // ras (bv. KWPN)
  dateOfBirth DateTime?
  sex         HorseSex?
  color       String? // vachtkleur
  chipNumber  String? // chip (15 cijfers)
  ueln        String? // UELN (internationaal ID)
  passportNumber String? // paspoortnummer
  boxNumber   String? // stalplek binnen de stal

  // Afstamming
  sireName    String? // vader
  damName     String? // moeder

  // Sport
  discipline      String?
  disciplineLevel String?

  // Twee onafhankelijke, naast elkaar bestaande kenmerken van het paard:
  //  - As 1: relatietype (relatie/eigendom met de stal). Stal/extern volgt
  //    impliciet uit deze waarde; de concrete externe eigenaar uit
  //    HorsePerson.isOwner = true. Nullable: nog niet altijd ingevuld.
  //  - As 2: stallingsvorm (afgenomen dienst), los van As 1. Nullable.
  relatietype   HorseRelatietype?
  stallingsvorm HorseStallingsvorm?

  // Eigendom: is dit paard van de stal zelf (manege/lespaard/stalpaard) of van een
  // particuliere eigenaar? Expliciet en losgekoppeld van `relatietype` (dat blijft
  // beschrijvend "soort paard"). Bron van waarheid voor "wie is eigenaar":
  //  - STAL        → eigenaar = de stal (Horse.stableId); geen HorsePerson-eigenaar nodig.
  //  - PARTICULIER → eigenaar = de HorsePerson met isOwner = true.
  // Bepaalt o.a. of een (lease)contract opgesteld kan worden zonder gekoppelde
  // eigenaar-User (bij STAL is de stal de eigenaar).
  eigendom HorseEigendom @default(PARTICULIER)

  // Profielfoto (#118): pad in de privé Supabase Storage-bucket `horse-photos`.
  // Net als het stallogo bewaren we enkel het storage-pad; de foto zelf staat in
  // Storage en wordt server-side via een signed URL (UI) of data-URL (PDF) ingezien.
  photoPath String?

  // Welzijn / EU
  excludedFromConsumption     Boolean   @default(false)
  excludedFromConsumptionDate DateTime?

  // Een paard staat (in de MVP) op precies één pensionstal.
  stableId String @db.Uuid
  stable   Stable @relation(fields: [stableId], references: [id], onDelete: Restrict)

  // Aan het paard gekoppelde personen (eigenaar en/of bereider). Account-gekoppeld
  // via HorsePerson; rollen als aan/uit-vlaggen (isOwner / isRider).
  people HorsePerson[]

  // Gezondheidsregistratie (stap 3)
  vaccinations    Vaccination[]
  dewormings      Deworming[]
  vetVisits       VetVisit[]
  hoefsmitBezoeken HoefsmitBezoek[]
  bodyMeasurements BodyMeasurement[]
  tasks           Task[]
  messages        Message[]
  recurringTasks  RecurringTask[]
  feedingPlan     FeedingPlan?
  contracts       Contract[]

  // Paardenlease-module (#59). Lease-aanbod (marktplaats) en actieve lease-
  // overeenkomsten hangen aan het centrale paardprofiel.
  leaseListings   LeaseListing[]
  leases          Lease[]
  // Geclaimde dagdelen in de beschikbaarheidskalender (Lease 09, #68).
  dagdeelClaims   LeaseDagdeelClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stableId])
}

enum HorseSex {
  MARE     // merrie
  STALLION // hengst
  GELDING  // ruin
}

// As 1 — Relatietype: relatie/eigendom van het paard met de stal. Eén waarde
// per paard. Vervangt het oude boolean-veld ownedByStable.
enum HorseRelatietype {
  STALPAARD          // stalpaard / eigen paard (eigendom van de stal)
  PENSIONPAARD       // pensionpaard (gestald door externe eigenaar)
  LESPAARD           // lespaard / manegepaard
  LEASEPAARD         // leasepaard
  TRAININGSPAARD     // trainings- / beleerpaard
  VERKOOPPAARD       // verkoop- / handelspaard
  FOKPAARD           // fokpaard
  OPFOKPAARD         // opfokpaard
  REVALIDATIEPAARD   // revalidatie- / herstelpaard
  RUSTPAARD          // rust- / pensioenpaard
}

// Eigendom van het paard — binair, los van het beschrijvende `relatietype` (As 1).
// STAL = eigendom van de stal zelf (manege/les-/stalpaard); PARTICULIER = een
// particuliere (externe) eigenaar, gekoppeld via HorsePerson.isOwner.
enum HorseEigendom {
  STAL
  PARTICULIER
}

// As 2 — Stallingsvorm: afgenomen stallingsdienst, los van het relatietype.
// Eén waarde per paard.
enum HorseStallingsvorm {
  VOLLEDIG_PENSION // volledig pension
  HALFPENSION      // halfpension
  WEIDESTALLING    // weidestalling / grass livery
  PADDOCK          // paddock / trailbox
  TIJDELIJK        // tijdelijke / nachtstalling
}

// Koppelt een persoon (account) aan een paard met een of beide rollen:
// eigenaar (isOwner) en/of bereider (isRider). Zowel eigenaar als bereider
// kan inloggen en krijgt leestoegang tot het gekoppelde paardprofiel.
//
// App-invariant: minstens één rol actief (isOwner || isRider). Een koppeling
// zonder rol bestaat niet — bij het uitzetten van de laatste rol wordt de rij
// verwijderd. Dit wordt afgedwongen in de app-laag (actions).
model HorsePerson {
  id        String   @id @default(uuid()) @db.Uuid
  horseId   String   @db.Uuid
  userId    String   @db.Uuid
  isOwner   Boolean  @default(false)
  isRider   Boolean  @default(false)
  createdAt DateTime @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([horseId, userId])
  @@index([userId])
}

// ── Gezondheidsregistratie ───────────────────────────────────────────────────

model Vaccination {
  id        String    @id @default(uuid()) @db.Uuid
  horseId   String    @db.Uuid
  date      DateTime
  type      String
  nextDate  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
}

model Deworming {
  id        String    @id @default(uuid()) @db.Uuid
  horseId   String    @db.Uuid
  date      DateTime
  product   String
  nextDate  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
}

model VetVisit {
  id        String   @id @default(uuid()) @db.Uuid
  horseId   String   @db.Uuid
  date      DateTime
  vet       String?
  reason    String
  notes     String?
  createdAt DateTime @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
}

// ── Dagelijkse taken ─────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  stableId    String    @db.Uuid
  horseId     String?   @db.Uuid
  title       String
  date        DateTime  @db.Date
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  zorgType    ZorgType?
  createdAt   DateTime  @default(now())

  stable Stable  @relation(fields: [stableId], references: [id], onDelete: Cascade)
  horse  Horse?  @relation(fields: [horseId], references: [id], onDelete: SetNull)

  @@index([stableId, date])
}

// ── Berichten (stap 5) ───────────────────────────────────────────────────────
// Eén generiek berichtmodel. Precies één doel is gezet:
//   - stableId  → stalbericht (zichtbaar voor stalleden + paardeneigenaren van de stal)
//   - horseId   → paardbericht (zichtbaar voor stalleden + eigenaren van dat paard)
// Het "precies één doel"-invariant wordt afgedwongen in de app-laag (actions) en
// met een CHECK-constraint in de migratie.

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  stableId  String?  @db.Uuid
  horseId   String?  @db.Uuid
  authorId  String   @db.Uuid
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stable Stable? @relation(fields: [stableId], references: [id], onDelete: Cascade)
  horse  Horse?  @relation(fields: [horseId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reads  MessageRead[]

  @@index([stableId])
  @@index([horseId])
}

// Per gebruiker per bericht: gelezen-status. Voedt de meldingen-bel in de topbar.
model MessageRead {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// ── Terugkerende taken ───────────────────────────────────────────────────────

enum RecurringFreq {
  DAILY
  WEEKLY
  MONTHLY
}

model RecurringTask {
  id         String        @id @default(uuid()) @db.Uuid
  stableId   String        @db.Uuid
  horseId    String?       @db.Uuid
  title      String
  frequency  RecurringFreq
  dayOfWeek  Int?          // 0=ma t/m 6=zo; alleen bij WEEKLY
  dayOfMonth Int?          // 1-28; alleen bij MONTHLY
  isActive   Boolean       @default(true)
  zorgType   ZorgType?
  createdAt  DateTime      @default(now())

  stable Stable  @relation(fields: [stableId], references: [id], onDelete: Cascade)
  horse  Horse?  @relation(fields: [horseId], references: [id], onDelete: SetNull)

  @@index([stableId])
}

// ── Hoefsmitbezoeken ─────────────────────────────────────────────────────────

model HoefsmitBezoek {
  id        String    @id @default(uuid()) @db.Uuid
  horseId   String    @db.Uuid
  horse     Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
  date      DateTime
  hoefsmid  String?
  nextDate  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([horseId])
}

// ── Gewicht & metingen ───────────────────────────────────────────────────────
// Conditie-/groeiregistratie per paard (gewicht, stokmaat, BCS). Bewust géén
// nextDate: een meting kent geen herhaalvervaldatum. Bij invoer is minimaal
// `date` plus ten minste één meetwaarde vereist (app-laag valideert dat).
model BodyMeasurement {
  id                 String    @id @default(uuid()) @db.Uuid
  horseId            String    @db.Uuid
  horse              Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
  date               DateTime
  weightKg           Float?
  heightCm           Int?
  bodyConditionScore Float?
  measuredBy         String?
  notes              String?
  createdAt          DateTime  @default(now())

  @@index([horseId])
}

// ── Voederschema (rantsoenkaart) ─────────────────────────────────────────────
// Eén-op-één met Horse: precies één voederschema per paard. Bewust vrije
// tekstvelden, simpel voor de MVP. Staf/eigenaar van de stal mag schrijven;
// paardeneigenaar mag alleen lezen.

model FeedingPlan {
  id           String   @id @default(uuid()) @db.Uuid
  horseId      String   @unique @db.Uuid
  roughage     String? // ruwvoer (bv. 3x daags hooi)
  concentrate  String? // krachtvoer (bv. 2 scheppen muesli ochtend en avond)
  supplements  String? // supplementen
  restrictions String? // beperkingen/allergie (bv. geen suikerrijk voer)
  notes        String? // overige opmerkingen
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

// ── Zorgtype enum ─────────────────────────────────────────────────────────────

enum ZorgType {
  VACCINATIE
  ONTWORMING
  DIERENARTS
  HOEFSMIT
}

// ── Contracten (stalling + lease) ────────────────────────────────────────────
// Fundament voor de contracten-module. STAL-01 levert het concept-stallingscontract
// (full pension). Latere stories breiden uit met opties, prijs, looptijd, verzekering,
// statusovergangen en de lease-familie. Houd dit datamodel daarom generiek.
//
// De wederpartij (counterpartyUserId) verwijst naar een User die via HorsePerson
// (isOwner = true) aan het paard gekoppeld is — de paardeigenaar. Nullable tot er
// een eigenaar gekozen is.

model Contract {
  id      String @id @default(uuid()) @db.Uuid
  horseId String @db.Uuid
  horse   Horse  @relation(fields: [horseId], references: [id], onDelete: Cascade)

  stableId String @db.Uuid
  stable   Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)

  // Contract-familie + type. v1: family=STALLING, type="FULL_PENSION".
  family ContractFamily
  type   String

  // Wederpartij (paardeigenaar). Nullable tot gekozen.
  counterpartyUserId String? @db.Uuid
  counterparty       User?   @relation("ContractCounterparty", fields: [counterpartyUserId], references: [id], onDelete: SetNull)

  status         ContractStatus @default(CONCEPT)
  currentVersion Int            @default(1)

  // Ingangsdatum van de overeenkomst. Nullable tot ingevuld.
  startDate DateTime?

  // Ruimte voor config-velden die latere stories invullen (opties, prijs, looptijd,
  // verzekering). Bewust als JSON zodat het schema niet bij elke story migreert.
  config Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Gegenereerde PDF-documenten per versie (STAL-12). Bij aanbieden (STAL-08) en
  // bij elke nieuwe versie (STAL-11) wordt een PDF naar Supabase Storage geschreven
  // en hier als ContractDocument gekoppeld.
  documents ContractDocument[]

  // Door de stal aangeleverde bijlagen (STAL-16): stalreglement, voerschema,
  // prijslijst, kopie verzekeringspolis. Andere documenten dan de gegenereerde
  // contract-PDF; daarom een eigen koppelmodel (ContractBijlage).
  bijlagen ContractBijlage[]

  // 1:1-koppeling naar de operationele Lease (contract-unify, [Unify 01] #127).
  // Een lease-Contract (family=LEASE) brengt straks bij activatie ([Unify 06] #132)
  // een 1:1 gekoppelde Lease voort. Die Lease — niet het contract — stuurt het
  // operationele gevolg aan: leaser-toegang tot het paardprofiel, de gedeelde
  // kalender (deellease) en de mijlpaal-/notificatiemotor. De leaser-toegang blijft
  // dus afgeleid van een ACTIEVE Lease, niet van het Contract. Back-relation; de FK
  // (contractId, @unique) staat op Lease.
  lease Lease?

  // Facturen die uit dit contract voortkomen (Fact 01). Optionele bron; een factuur
  // overleeft het verwijderen van zijn bron-contract (onDelete: SetNull op Invoice).
  invoices Invoice[]

  @@index([horseId])
  @@index([stableId])
  @@index([counterpartyUserId])
}

// ── Contract-bijlagen (STAL-16) ──────────────────────────────────────────────
// Door de stal geüploade bijlagen die documentair bij een contract horen
// (stalreglement, voerschema, prijslijst, kopie verzekeringspolis). Het bestand
// staat in Supabase Storage (bucket voor contract-bijlagen); hier bewaren we het
// storage-pad, de oorspronkelijke bestandsnaam en de categorie. Per categorie zijn
// meerdere of geen bijlagen mogelijk. Inzage voor de paardeigenaar loopt — net als
// de contract-PDF — via een signed URL met dezelfde leesrechten als de eigenaar-
// weergave van het paard.
model ContractBijlage {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @db.Uuid
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // Categorie van de bijlage (STALREGLEMENT, VOERSCHEMA, PRIJSLIJST, VERZEKERINGSPOLIS).
  categorie String

  // Oorspronkelijke bestandsnaam (voor weergave/download).
  bestandsnaam String

  // Pad/key van het bestand binnen de Supabase Storage-bucket.
  storagePath String

  createdAt DateTime @default(now())

  @@index([contractId])
}

// ── Contract-PDF (STAL-12) ───────────────────────────────────────────────────
// Per gegenereerde en opgeslagen contract-PDF één rij. De PDF zelf staat in
// Supabase Storage (bucket voor contract-PDF's); hier bewaren we het storage-pad
// (key binnen de bucket) plus het versienummer waarvoor de PDF is gegenereerd.
// Eigenaar-inzage loopt via een signed URL, met dezelfde leesrechten als de
// eigenaar-weergave van het paard (STAL-09).
model ContractDocument {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @db.Uuid
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // Versie van het contract (Contract.currentVersion) op het moment van genereren.
  version Int

  // Pad/key van het bestand binnen de Supabase Storage-bucket.
  storagePath String

  createdAt DateTime @default(now())

  @@index([contractId])
}

enum ContractFamily {
  STALLING
  LEASE
}

enum ContractStatus {
  CONCEPT
  AANGEBODEN
  GEACCEPTEERD
  ACTIEF
  OPGESCHORT
  OPZEGGING_LOOPT
  VERLENGD
  BEEINDIGD
  VERLOPEN
  GEANNULEERD
  AFGEWEZEN
  VERVANGEN
}

// ── Autorisatie-logica (in app-laag, niet in schema) ─────────────────────────
// Mag gebruiker U paard H zien?
//   - U is OWNER/STAFF van H.stable  (via StableMember), OF
//   - U is eigenaar of bereider van H (via HorsePerson), OF
//   - U is leaser met een ACTIEVE Lease op H (paardenlease-module #59, Lease 02).
// Bewerken: stal OWNER/STAFF mag alles van paarden op hun stal;
// paardeneigenaar/bereider/leaser krijgt beperkte (lees)rechten op eigen paard.

// ── Paardenlease-module (#59) ────────────────────────────────────────────────
// Fundament voor de leasemodule (Lease 01). Twee modellen hangen aan het centrale
// paardprofiel (Horse):
//   - LeaseListing: een lease-AANBOD op de marktplaats (vraag/aanbod), los van een
//     concrete leaser. (De)activeerbaar via isActive.
//   - Lease: een concrete OVEREENKOMST die een leaser (User) aan een paard koppelt,
//     met levenscyclus (status) en de termijnvelden waar latere stories (kosten,
//     verzekering, kalender, notificaties) op voortbouwen.
// Bewust géén bedragen/kostenverdeling of contractinhoud hier: die volgen als JSON/
// eigen modellen in Lease 06/07. Dit is alleen de kern + relaties + migratie.

model LeaseListing {
  id      String @id @default(uuid()) @db.Uuid
  horseId String @db.Uuid
  horse   Horse  @relation(fields: [horseId], references: [id], onDelete: Cascade)

  leaseType     LeaseType
  daysPerWeek   Int? // bij deellease/bijrijden: aantal dagen per week
  pricePerMonth Decimal? @db.Decimal(10, 2) // leasevergoeding per maand
  region        String? // regio voor de marktplaats-filters (Lease 04)
  discipline    String?
  movable       Boolean  @default(false) // mag het paard verplaatst worden?
  exclusive     Boolean  @default(true) // exclusief (één leaser) vs. gedeeld gebruik
  description   String?
  isActive      Boolean  @default(true) // bepaalt publieke zichtbaarheid op de marktplaats

  // Interesse-gesprekken op dit aanbod (Lease 05, #64).
  inquiries LeaseInquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([horseId])
  @@index([isActive])
}

model Lease {
  id      String @id @default(uuid()) @db.Uuid
  horseId String @db.Uuid
  horse   Horse  @relation(fields: [horseId], references: [id], onDelete: Cascade)

  // De leaser (account). Een actieve Lease geeft deze gebruiker leestoegang tot het
  // paardprofiel (Lease 02).
  leaserUserId String @db.Uuid
  leaser       User   @relation(fields: [leaserUserId], references: [id], onDelete: Cascade)

  // 1:1-koppeling naar het bron-Contract (contract-unify, [Unify 01] #127).
  // Nullable omdat (a) bestaande Lease-rijen geen contract hebben en (b) de koppeling
  // pas bij activatie van een lease-Contract ontstaat ([Unify 06] #132). @unique dwingt
  // de 1:1-cardinaliteit af. onDelete: SetNull zodat de operationele Lease (en daarmee
  // leaser-toegang/historie) het verwijderen van zijn Contract overleeft.
  contractId String?   @unique @db.Uuid
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  leaseType         LeaseType
  status            LeaseStatus @default(CONCEPT)
  startDate         DateTime?
  endDate           DateTime?
  minimumTermMonths Int? // minimale looptijd in maanden
  noticePeriodDays  Int? // opzegtermijn in dagen
  trialEndsAt       DateTime? // einde proefperiode

  // Rijke contractinhoud + ondertekening (Lease 06, #65) als JSON, zodat het schema
  // niet bij elke contract-uitbreiding hoeft te migreren — net als Contract.config.
  config Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([horseId])
  @@index([leaserUserId])
  @@index([status])
}

// Leasevormen (Nederlandse labels in src/features/lease/leaseHelpers.ts).
enum LeaseType {
  FULL // full lease (volledige lease)
  DEEL // deellease / halflease (gedeeld gebruik)
  BIJRIJDEN // bijrijden (co-rider, lichtste vorm)
  WEDSTRIJD // wedstrijdlease
  KOOPOPTIE // lease met koopoptie
  FOK // foklease
}

enum LeaseStatus {
  CONCEPT // opgesteld, nog niet actief
  ACTIEF // lopende lease (geeft leestoegang)
  OPGEZEGD // opzegging loopt
  BEEINDIGD // afgerond
}

// ── Lease-interesse / in-app contact (Lease 05, #64) ─────────────────────────
// Eén-op-één gesprekthread tussen een geïnteresseerde (inquirer) en de aanbieder
// (de stal van het paard) over een specifiek lease-aanbod. Bewust een eigen, licht
// model i.p.v. het broadcast Message-model: berichten zijn hier privé tussen twee
// partijen en hangen aan een listing. Eén thread per geïnteresseerde per aanbod.
model LeaseInquiry {
  id        String       @id @default(uuid()) @db.Uuid
  listingId String       @db.Uuid
  listing   LeaseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  inquirerUserId String @db.Uuid
  inquirer       User   @relation("LeaseInquirer", fields: [inquirerUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages LeaseInquiryMessage[]

  @@unique([listingId, inquirerUserId])
  @@index([listingId])
  @@index([inquirerUserId])
}

model LeaseInquiryMessage {
  id        String       @id @default(uuid()) @db.Uuid
  inquiryId String       @db.Uuid
  inquiry   LeaseInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  authorId String @db.Uuid
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body   String
  readAt DateTime? // gelezen door de wederpartij (null = ongelezen)

  createdAt DateTime @default(now())

  @@index([inquiryId])
}

// ── Beschikbaarheidskalender (Lease 09, #68) ─────────────────────────────────
// Eén claim = één persoon die een dagdeel van een paard claimt op een concrete dag.
// Bij (deel)lease voorkomt dit dat meerdere partijen tegelijk willen rijden. De
// unieke sleutel (paard + datum + dagdeel) borgt conflictpreventie op databaseniveau.
model LeaseDagdeelClaim {
  id      String @id @default(uuid()) @db.Uuid
  horseId String @db.Uuid
  horse   Horse  @relation(fields: [horseId], references: [id], onDelete: Cascade)
  userId  String @db.Uuid
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  datum   DateTime @db.Date
  dagdeel String // OCHTEND | MIDDAG | AVOND

  createdAt DateTime @default(now())

  @@unique([horseId, datum, dagdeel])
  @@index([horseId])
  @@index([userId])
}

// ── Facturatie (#145, Fact 01) ───────────────────────────────────────────────
// Fundament voor de facturatie-module: de kern-entiteiten Invoice + InvoiceLine.
// Stap 6 uit de bouwvolgorde (CLAUDE.md). Sluit de keten matching → contract →
// administratie → facturatie rond het centrale paardprofiel. Bewust een puur
// fundament-model: geen UI/actions/queries, geen factuurnummer-generatie of
// statusovergangslogica — die volgen in Fact 02–07.
//
// Relaties:
//   - stableId        → de uitgevende stal (afzender). onDelete: Cascade.
//   - recipientUserId → de ontvanger (paardeigenaar/leaser). Nullable +
//     onDelete: SetNull, zodat een factuur de verwijdering van het account overleeft
//     (administratie/historie blijft behouden).
//   - contractId      → optionele bron (stallings- of leasecontract). onDelete:
//     SetNull, zodat de factuur het verwijderen van zijn bron-contract overleeft.
//
// Bedragen zijn gedenormaliseerd opgeslagen (subtotal/vatAmount/total) zodat een
// factuur het bedrag op uitgiftemoment vastlegt; de berekening/optelling hoort in
// een latere story (app-laag).
model Invoice {
  id String @id @default(uuid()) @db.Uuid

  // Uitgevende stal (afzender).
  stableId String @db.Uuid
  stable   Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)

  // Ontvanger (paardeigenaar/leaser). Nullable; factuur overleeft accountverwijdering.
  recipientUserId String? @db.Uuid
  recipient       User?   @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  // Optionele bron (stallings-/leasecontract). Factuur overleeft contractverwijdering.
  contractId String?   @db.Uuid
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  // Concept-facturen hebben nog geen definitief nummer; opvolgende nummering wordt
  // pas in Fact 05 toegekend. @unique borgt dat dubbele nummers op DB-niveau
  // onmogelijk zijn.
  invoiceNumber String? @unique

  // Nullable tot vastgesteld.
  invoiceDate DateTime?
  dueDate     DateTime?

  status InvoiceStatus @default(CONCEPT)

  // Totalen gedenormaliseerd vastgelegd (excl. btw / totale btw / incl. btw).
  subtotal  Decimal @default(0) @db.Decimal(10, 2)
  vatAmount Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @default(0) @db.Decimal(10, 2)

  // Vrije opmerking op de factuur.
  notes String?

  lines InvoiceLine[]
  // Gegenereerde factuur-PDF's (Fact 05). Laatste document = de actuele PDF.
  documents InvoiceDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stableId])
  @@index([recipientUserId])
  @@index([contractId])
}

// Eén factuurregel. Het btw-tarief staat per regel (vatRate), niet alleen op
// factuurniveau. quantity is Decimal i.p.v. Int zodat deelperiodes (bv. halve
// maanden) mogelijk zijn.
model InvoiceLine {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Decimal @db.Decimal(10, 2) // aantal (deelperiodes mogelijk)
  unitPrice   Decimal @db.Decimal(10, 2) // stuksprijs excl. btw
  vatRate     VatRate // btw-tarief per regel
  lineTotal   Decimal @db.Decimal(10, 2) // regelbedrag excl. btw

  // Bewaart de regelvolgorde stabiel.
  position Int @default(0)

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

enum InvoiceStatus {
  CONCEPT
  VERZONDEN
  BETAALD
  VERVALLEN
  GEANNULEERD
}

// ── Gegenereerde factuur-PDF (Fact 05) ────────────────────────────────────────
// Spiegelt ContractDocument: de gegenereerde factuur-PDF wordt in een privé
// Supabase Storage-bucket opgeslagen en hier per factuur gekoppeld via het
// storagePath (key binnen de bucket). Inzage loopt via een signed URL met dezelfde
// leesrechten als de eigenaar-/stalweergave (Fact 02). Het laatste document wint
// (newest-first), zoals bij ContractDocument.
model InvoiceDocument {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Pad/key van het bestand binnen de Supabase Storage-bucket.
  storagePath String

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

// ── Race-safe, jaargebonden factuurnummer-reeks (Fact 05) ─────────────────────
// Per stal en per jaar een eigen, lopende teller. Het ophogen gebeurt atomair
// binnen dezelfde transactie als het toekennen van het factuurnummer (upsert met
// increment), zodat parallelle "definitief maken"-acties geen dubbel of
// overgeslagen nummer kunnen produceren. De @unique op Invoice.invoiceNumber blijft
// het harde DB-vangnet. Bij jaarwissel begint een nieuwe rij bij 1.
model InvoiceNumberSequence {
  id         String @id @default(uuid()) @db.Uuid
  stableId   String @db.Uuid
  year       Int
  lastNumber Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stableId, year])
}

// Toegestane btw-tarieven. De numerieke percentages (0/9/21%) worden in de app-laag
// aan de enum gekoppeld (latere story), niet als losse kolom.
enum VatRate {
  NUL  // 0%
  LAAG // 9%
  HOOG // 21%
}
