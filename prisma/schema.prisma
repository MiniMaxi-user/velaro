// Velaro MVP — datamodel (stap 1)
// Scope: pensionstal-beachhead, rond het centrale paardenprofiel.
// Alleen de kern-entiteiten. Gezondheid/planning/facturatie volgen in latere stappen
// en haken aan op Horse — nu nog NIET modelleren (premature complexiteit).
//
// Auth: Supabase Auth doet authenticatie. Elke User-rij spiegelt een auth-user:
//   User.id == auth.users.id (uuid). Autorisatie regelen wij in de app-laag op basis
//   van StableMember (stalrol) en HorseOwner (eigendom).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Gebruikers ──────────────────────────────────────────────────────────────

model User {
  id              String   @id @db.Uuid // == Supabase auth user id
  email           String   @unique
  name            String?
  isPlatformAdmin Boolean  @default(false)
  maxStables      Int      @default(0)

  // ── Zakelijke / facturatiegegevens (fundament voor facturatie) ──────────────
  // Allemaal optioneel zodat bestaande accounts geldig blijven. Plat gehouden,
  // conform de adresconventie op Stable. Primair bedoeld voor staleigenaar-accounts
  // (de te factureren klant).
  companyName   String? // bedrijfs-/factuurnaam
  address       String?
  postalCode    String?
  city          String?
  country       String?
  kvkNumber     String? // KvK-nummer
  vatNumber     String? // btw-nummer

  // Afwijkend factuuradres: pas relevant wanneer aangevinkt. Staat dit uit, dan
  // geldt het hoofdadres hierboven als factuuradres.
  separateInvoiceAddress Boolean @default(false)
  invoiceAddress         String?
  invoicePostalCode      String?
  invoiceCity            String?
  invoiceCountry         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Een gebruiker kan staf/eigenaar van stallen zijn én eigenaar/bereider van paarden.
  stableMemberships StableMember[]
  horsePeople       HorsePerson[]
  messages          Message[]
  messageReads      MessageRead[]
  // Contracten waarin deze gebruiker de wederpartij (paardeigenaar) is.
  counterpartyContracts Contract[] @relation("ContractCounterparty")
}

// ── Stal (pensionbedrijf) ────────────────────────────────────────────────────

model Stable {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  // Adres bewust plat gehouden voor de MVP.
  address    String?
  postalCode String?
  city       String?

  // Contactgegevens
  phone   String?
  email   String?
  website String?

  // Omschrijving / over de stal
  description String?

  // Eigen stallogo (huisstijl) voor o.a. de contract-PDF. Verwijst naar het pad/key
  // binnen de privé Supabase Storage-bucket voor stallogo's; null = standaard
  // Velaro-logo. Per stal instelbaar (een OWNER met meerdere stallen kan per stal
  // een ander logo hebben).
  logoPath String?

  // Openingstijden (vrij tekstveld, bv. "Ma-vr 07:00-21:00")
  openingHours String?

  // Factuuradres (indien afwijkend)
  invoiceAddress    String?
  invoicePostalCode String?
  invoiceCity       String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members        StableMember[]
  horses         Horse[]
  tasks          Task[]
  recurringTasks RecurringTask[]
  messages       Message[]
  contracts      Contract[]
}

// Koppelt een gebruiker aan een stal met een rol (staf/eigenaar van de stal).
// Dit bepaalt of iemand alle paarden ván die stal mag zien/beheren.
model StableMember {
  id        String     @id @default(uuid()) @db.Uuid
  stableId  String     @db.Uuid
  userId    String     @db.Uuid
  role      StableRole
  createdAt DateTime   @default(now())

  stable Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stableId, userId])
  @@index([userId])
}

enum StableRole {
  OWNER // staleigenaar — volledige rechten binnen de stal
  STAFF // stalmedewerker — beperktere rechten
}

// ── Paard (centraal profiel) ─────────────────────────────────────────────────

model Horse {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  // Basisgegevens — uit te breiden, maar dit is de kern.
  breed       String? // ras (bv. KWPN)
  dateOfBirth DateTime?
  sex         HorseSex?
  color       String? // vachtkleur
  chipNumber  String? // chip (15 cijfers)
  ueln        String? // UELN (internationaal ID)
  passportNumber String? // paspoortnummer
  boxNumber   String? // stalplek binnen de stal

  // Afstamming
  sireName    String? // vader
  damName     String? // moeder

  // Sport
  discipline      String?
  disciplineLevel String?

  // Eigendom: true = stalpaard (eigendom van de stal zelf),
  // false = pensionpaard (gestald door een externe eigenaar).
  // Sluit elkaar uit: een stalpaard heeft geen externe HorseOwner-koppeling.
  ownedByStable Boolean @default(true)

  // Welzijn / EU
  excludedFromConsumption     Boolean   @default(false)
  excludedFromConsumptionDate DateTime?

  // Een paard staat (in de MVP) op precies één pensionstal.
  stableId String @db.Uuid
  stable   Stable @relation(fields: [stableId], references: [id], onDelete: Restrict)

  // Aan het paard gekoppelde personen (eigenaar en/of bereider). Account-gekoppeld
  // via HorsePerson; rollen als aan/uit-vlaggen (isOwner / isRider).
  people HorsePerson[]

  // Gezondheidsregistratie (stap 3)
  vaccinations    Vaccination[]
  dewormings      Deworming[]
  vetVisits       VetVisit[]
  hoefsmitBezoeken HoefsmitBezoek[]
  tasks           Task[]
  messages        Message[]
  recurringTasks  RecurringTask[]
  feedingPlan     FeedingPlan?
  contracts       Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stableId])
}

enum HorseSex {
  MARE     // merrie
  STALLION // hengst
  GELDING  // ruin
}

// Koppelt een persoon (account) aan een paard met een of beide rollen:
// eigenaar (isOwner) en/of bereider (isRider). Zowel eigenaar als bereider
// kan inloggen en krijgt leestoegang tot het gekoppelde paardprofiel.
//
// App-invariant: minstens één rol actief (isOwner || isRider). Een koppeling
// zonder rol bestaat niet — bij het uitzetten van de laatste rol wordt de rij
// verwijderd. Dit wordt afgedwongen in de app-laag (actions).
model HorsePerson {
  id        String   @id @default(uuid()) @db.Uuid
  horseId   String   @db.Uuid
  userId    String   @db.Uuid
  isOwner   Boolean  @default(false)
  isRider   Boolean  @default(false)
  createdAt DateTime @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([horseId, userId])
  @@index([userId])
}

// ── Gezondheidsregistratie ───────────────────────────────────────────────────

model Vaccination {
  id        String    @id @default(uuid()) @db.Uuid
  horseId   String    @db.Uuid
  date      DateTime
  type      String
  nextDate  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
}

model Deworming {
  id        String    @id @default(uuid()) @db.Uuid
  horseId   String    @db.Uuid
  date      DateTime
  product   String
  nextDate  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
}

model VetVisit {
  id        String   @id @default(uuid()) @db.Uuid
  horseId   String   @db.Uuid
  date      DateTime
  vet       String?
  reason    String
  notes     String?
  createdAt DateTime @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
}

// ── Dagelijkse taken ─────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  stableId    String    @db.Uuid
  horseId     String?   @db.Uuid
  title       String
  date        DateTime  @db.Date
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  zorgType    ZorgType?
  createdAt   DateTime  @default(now())

  stable Stable  @relation(fields: [stableId], references: [id], onDelete: Cascade)
  horse  Horse?  @relation(fields: [horseId], references: [id], onDelete: SetNull)

  @@index([stableId, date])
}

// ── Berichten (stap 5) ───────────────────────────────────────────────────────
// Eén generiek berichtmodel. Precies één doel is gezet:
//   - stableId  → stalbericht (zichtbaar voor stalleden + paardeneigenaren van de stal)
//   - horseId   → paardbericht (zichtbaar voor stalleden + eigenaren van dat paard)
// Het "precies één doel"-invariant wordt afgedwongen in de app-laag (actions) en
// met een CHECK-constraint in de migratie.

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  stableId  String?  @db.Uuid
  horseId   String?  @db.Uuid
  authorId  String   @db.Uuid
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stable Stable? @relation(fields: [stableId], references: [id], onDelete: Cascade)
  horse  Horse?  @relation(fields: [horseId], references: [id], onDelete: Cascade)
  author User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reads  MessageRead[]

  @@index([stableId])
  @@index([horseId])
}

// Per gebruiker per bericht: gelezen-status. Voedt de meldingen-bel in de topbar.
model MessageRead {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

// ── Terugkerende taken ───────────────────────────────────────────────────────

enum RecurringFreq {
  DAILY
  WEEKLY
  MONTHLY
}

model RecurringTask {
  id         String        @id @default(uuid()) @db.Uuid
  stableId   String        @db.Uuid
  horseId    String?       @db.Uuid
  title      String
  frequency  RecurringFreq
  dayOfWeek  Int?          // 0=ma t/m 6=zo; alleen bij WEEKLY
  dayOfMonth Int?          // 1-28; alleen bij MONTHLY
  isActive   Boolean       @default(true)
  zorgType   ZorgType?
  createdAt  DateTime      @default(now())

  stable Stable  @relation(fields: [stableId], references: [id], onDelete: Cascade)
  horse  Horse?  @relation(fields: [horseId], references: [id], onDelete: SetNull)

  @@index([stableId])
}

// ── Hoefsmitbezoeken ─────────────────────────────────────────────────────────

model HoefsmitBezoek {
  id        String    @id @default(uuid()) @db.Uuid
  horseId   String    @db.Uuid
  horse     Horse     @relation(fields: [horseId], references: [id], onDelete: Cascade)
  date      DateTime
  hoefsmid  String?
  nextDate  DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([horseId])
}

// ── Voederschema (rantsoenkaart) ─────────────────────────────────────────────
// Eén-op-één met Horse: precies één voederschema per paard. Bewust vrije
// tekstvelden, simpel voor de MVP. Staf/eigenaar van de stal mag schrijven;
// paardeneigenaar mag alleen lezen.

model FeedingPlan {
  id           String   @id @default(uuid()) @db.Uuid
  horseId      String   @unique @db.Uuid
  roughage     String? // ruwvoer (bv. 3x daags hooi)
  concentrate  String? // krachtvoer (bv. 2 scheppen muesli ochtend en avond)
  supplements  String? // supplementen
  restrictions String? // beperkingen/allergie (bv. geen suikerrijk voer)
  notes        String? // overige opmerkingen
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  horse Horse @relation(fields: [horseId], references: [id], onDelete: Cascade)
}

// ── Zorgtype enum ─────────────────────────────────────────────────────────────

enum ZorgType {
  VACCINATIE
  ONTWORMING
  DIERENARTS
  HOEFSMIT
}

// ── Contracten (stalling + lease) ────────────────────────────────────────────
// Fundament voor de contracten-module. STAL-01 levert het concept-stallingscontract
// (full pension). Latere stories breiden uit met opties, prijs, looptijd, verzekering,
// statusovergangen en de lease-familie. Houd dit datamodel daarom generiek.
//
// De wederpartij (counterpartyUserId) verwijst naar een User die via HorsePerson
// (isOwner = true) aan het paard gekoppeld is — de paardeigenaar. Nullable tot er
// een eigenaar gekozen is.

model Contract {
  id      String @id @default(uuid()) @db.Uuid
  horseId String @db.Uuid
  horse   Horse  @relation(fields: [horseId], references: [id], onDelete: Cascade)

  stableId String @db.Uuid
  stable   Stable @relation(fields: [stableId], references: [id], onDelete: Cascade)

  // Contract-familie + type. v1: family=STALLING, type="FULL_PENSION".
  family ContractFamily
  type   String

  // Wederpartij (paardeigenaar). Nullable tot gekozen.
  counterpartyUserId String? @db.Uuid
  counterparty       User?   @relation("ContractCounterparty", fields: [counterpartyUserId], references: [id], onDelete: SetNull)

  status         ContractStatus @default(CONCEPT)
  currentVersion Int            @default(1)

  // Ingangsdatum van de overeenkomst. Nullable tot ingevuld.
  startDate DateTime?

  // Ruimte voor config-velden die latere stories invullen (opties, prijs, looptijd,
  // verzekering). Bewust als JSON zodat het schema niet bij elke story migreert.
  config Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Gegenereerde PDF-documenten per versie (STAL-12). Bij aanbieden (STAL-08) en
  // bij elke nieuwe versie (STAL-11) wordt een PDF naar Supabase Storage geschreven
  // en hier als ContractDocument gekoppeld.
  documents ContractDocument[]

  // Door de stal aangeleverde bijlagen (STAL-16): stalreglement, voerschema,
  // prijslijst, kopie verzekeringspolis. Andere documenten dan de gegenereerde
  // contract-PDF; daarom een eigen koppelmodel (ContractBijlage).
  bijlagen ContractBijlage[]

  @@index([horseId])
  @@index([stableId])
  @@index([counterpartyUserId])
}

// ── Contract-bijlagen (STAL-16) ──────────────────────────────────────────────
// Door de stal geüploade bijlagen die documentair bij een contract horen
// (stalreglement, voerschema, prijslijst, kopie verzekeringspolis). Het bestand
// staat in Supabase Storage (bucket voor contract-bijlagen); hier bewaren we het
// storage-pad, de oorspronkelijke bestandsnaam en de categorie. Per categorie zijn
// meerdere of geen bijlagen mogelijk. Inzage voor de paardeigenaar loopt — net als
// de contract-PDF — via een signed URL met dezelfde leesrechten als de eigenaar-
// weergave van het paard.
model ContractBijlage {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @db.Uuid
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // Categorie van de bijlage (STALREGLEMENT, VOERSCHEMA, PRIJSLIJST, VERZEKERINGSPOLIS).
  categorie String

  // Oorspronkelijke bestandsnaam (voor weergave/download).
  bestandsnaam String

  // Pad/key van het bestand binnen de Supabase Storage-bucket.
  storagePath String

  createdAt DateTime @default(now())

  @@index([contractId])
}

// ── Contract-PDF (STAL-12) ───────────────────────────────────────────────────
// Per gegenereerde en opgeslagen contract-PDF één rij. De PDF zelf staat in
// Supabase Storage (bucket voor contract-PDF's); hier bewaren we het storage-pad
// (key binnen de bucket) plus het versienummer waarvoor de PDF is gegenereerd.
// Eigenaar-inzage loopt via een signed URL, met dezelfde leesrechten als de
// eigenaar-weergave van het paard (STAL-09).
model ContractDocument {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @db.Uuid
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  // Versie van het contract (Contract.currentVersion) op het moment van genereren.
  version Int

  // Pad/key van het bestand binnen de Supabase Storage-bucket.
  storagePath String

  createdAt DateTime @default(now())

  @@index([contractId])
}

enum ContractFamily {
  STALLING
  LEASE
}

enum ContractStatus {
  CONCEPT
  AANGEBODEN
  GEACCEPTEERD
  ACTIEF
  OPGESCHORT
  OPZEGGING_LOOPT
  VERLENGD
  BEEINDIGD
  VERLOPEN
  GEANNULEERD
  AFGEWEZEN
  VERVANGEN
}

// ── Autorisatie-logica (in app-laag, niet in schema) ─────────────────────────
// Mag gebruiker U paard H zien?
//   - U is OWNER/STAFF van H.stable  (via StableMember), OF
//   - U is eigenaar of bereider van H (via HorsePerson).
// Bewerken: stal OWNER/STAFF mag alles van paarden op hun stal;
// paardeneigenaar/bereider krijgt beperkte (lees)rechten op eigen paard.
